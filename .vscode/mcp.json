{
  "inputs": [
    {
      "id": "atlassian-token",
      "type": "promptString",
      "description": "Atlassian API Token",
      "password": true
    }
  ],
  "servers": {
    "atlassian-mcp-server": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${input:atlassian-token}"
      }
    }
  }
}
